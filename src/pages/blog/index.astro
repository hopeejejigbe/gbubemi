---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Fashion, virtual try-on, and style for every skin tone and every size — from the team building Gbubemi."
>
  <div class="blog-hero">
    <span class="doc-label">The Gbubemi Blog</span>
    <h1>Style, see-it-first stories,<br />and fashion for every body</h1>
    <p>Honest takes on virtual try-on, shopping smarter online, and fashion that actually looks good on real women.</p>
  </div>

  <div class="post-grid">
    {posts.length === 0 && (
      <p class="empty-state">No posts published yet — first one coming soon.</p>
    )}
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="post-card">
        {post.data.heroImage && (
          <div class="card-image" style={`background-image: url(${post.data.heroImage})`}></div>
        )}
        <div class="card-body">
          {post.data.tags.length > 0 && (
            <span class="card-tag">{post.data.tags[0]}</span>
          )}
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <span class="card-date">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .blog-hero {
    text-align: center;
    padding: 4rem 2rem 3rem;
    background: var(--light);
    border-bottom: 1px solid var(--border);
  }

  .doc-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pink);
    background: rgba(229,0,126,0.08);
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 1.25rem;
  }

  .blog-hero h1 {
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    font-weight: 700;
    color: var(--black);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .blog-hero p {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .post-grid {
    max-width: 1080px;
    margin: 0 auto;
    padding: 3.5rem 2rem 5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--muted);
    padding: 3rem;
  }

  .post-card {
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 32px rgba(229,0,126,0.12);
  }

  .card-image {
    height: 180px;
    background-size: cover;
    background-position: center;
    background-color: var(--light);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-tag {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pink);
    margin-bottom: 0.6rem;
  }

  .card-body h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--black);
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 0.6rem;
  }

  .card-body p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex: 1;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--muted);
    opacity: 0.7;
  }
</style>
